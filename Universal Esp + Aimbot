local function setupEsp(playerObj)
    local boxFrame = Drawing.new("Square")
    boxFrame.Thickness = 1
    boxFrame.Filled = false
    
    local hBack = Drawing.new("Line")
    hBack.Thickness = 2
    hBack.Color = Color3.new(0, 0, 0)
    
    local hFill = Drawing.new("Line")
    hFill.Thickness = 2
    
    espCache[playerObj] = {Box = boxFrame, Health = hFill, HealthBack = hBack}
end

RunService.RenderStepped:Connect(function()
    if not menuOpen then return end
    
    local mPos = UserInputService:GetMouseLocation()
    local lockedTarget = nil
    local bestDist = fovRadius

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= localPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            
            if plr.Character:FindFirstChild(targetPart) and hum and hum.Health > 0 then
                local screenPos, isOnScreen = cam:WorldToViewportPoint(plr.Character[targetPart].Position)
                
                if isOnScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mPos).Magnitude
                    if dist < bestDist then 
                        bestDist = dist
                        lockedTarget = plr.Character[targetPart] 
                    end
                end
            end
            
            local activeCham = chamsFolder:FindFirstChild(plr.Name)
            if chamsOn then
                if not activeCham then 
                    activeCham = Instance.new("Highlight", chamsFolder)
                    activeCham.Name = plr.Name 
                end
                activeCham.Adornee = plr.Character
                activeCham.FillColor = chamsFill
                activeCham.FillTransparency = chamsFillTrans
                activeCham.OutlineColor = chamsOutline
                activeCham.OutlineTransparency = chamsOutlineTrans
                activeCham.DepthMode = occludeChams and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
            elseif activeCham then 
                activeCham:Destroy() 
            end
            
            if not espCache[plr] then 
                setupEsp(plr) 
            end
            
            local espDraws = espCache[plr]
            if hrp and hum and hum.Health > 0 and espOn then
                local rootScreen, rootVis = cam:WorldToViewportPoint(hrp.Position)
                
                if rootVis then
                    local topPos = cam:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.8, 0))
                    local botPos = cam:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3.5, 0))
                    local sizeY = botPos.Y - topPos.Y
                    local sizeX = sizeY / 1.8
                    
                    espDraws.Box.Visible = espBox
                    espDraws.Box.Size = Vector2.new(sizeX, sizeY)
                    espDraws.Box.Position = Vector2.new(rootScreen.X - sizeX / 2, rootScreen.Y - sizeY / 2)
                    espDraws.Box.Color = espCol
                    
                    if espHealthBar then
                        espDraws.HealthBack.Visible = true
                        espDraws.HealthBack.From = Vector2.new(rootScreen.X - sizeX / 2 - 4, rootScreen.Y + sizeY / 2)
                        espDraws.HealthBack.To = Vector2.new(rootScreen.X - sizeX / 2 - 4, rootScreen.Y - sizeY / 2)
                        
                        espDraws.Health.Visible = true
                        espDraws.Health.From = Vector2.new(rootScreen.X - sizeX / 2 - 4, rootScreen.Y + sizeY / 2)
                        local healthPerc = hum.Health / hum.MaxHealth
                        espDraws.Health.To = Vector2.new(rootScreen.X - sizeX / 2 - 4, (rootScreen.Y + sizeY / 2) - (sizeY * healthPerc))
                        espDraws.Health.Color = Color3.new(1, 0, 0):Lerp(Color3.new(0, 1, 0), healthPerc)
                    else 
                        espDraws.Health.Visible = false
                        espDraws.HealthBack.Visible = false 
                    end
                else 
                    espDraws.Box.Visible = false
                    espDraws.Health.Visible = false
                    espDraws.HealthBack.Visible = false 
                end
            else 
                espDraws.Box.Visible = false
                espDraws.Health.Visible = false
                espDraws.HealthBack.Visible = false 
            end
        end
    end

    fovOutline.Position = mPos
    fovOutline.Radius = fovRadius
    fovOutline.Visible = outlineOn
    fovOutline.Color = outlineCol
    fovOutline.Transparency = 1 - outlineTrans
    
    fovFill.Position = mPos
    fovFill.Radius = fovRadius
    fovFill.Visible = fillOn
    fovFill.Color = fillCol
    fovFill.Transparency = 1 - fillTrans

    if lockedTarget and (showName or showHealth or showDist) then
        local str = ""
        if showName then str = str .. lockedTarget.Parent.Name .. "\n" end
        if showHealth then str = str .. "HP: " .. math.floor(lockedTarget.Parent:FindFirstChildOfClass("Humanoid").Health) .. "\n" end
        if showDist then str = str .. math.floor((localPlayer.Character.Head.Position - lockedTarget.Position).Magnitude) .. "m" end
        
        targetText.Visible = true
        targetText.Text = str
        targetText.Position = mPos + Vector2.new(0, fovRadius + 10)
    else 
        targetText.Visible = false 
    end

    clearLines()
    if crossOn then
        local midPoint = mPos
        if followTarget and lockedTarget then 
            local tPos = cam:WorldToViewportPoint(lockedTarget.Position)
            midPoint = Vector2.new(tPos.X, tPos.Y) 
        end
        
        centerDot.Visible = crossDot
        centerDot.Position = midPoint
        centerDot.Color = crossCol
        centerDot.Radius = crossWidth
        centerDot.Transparency = 1 - crossTrans
        
        spinStep = spinStep + ((spinSpeed^2) / 400)
        
        for i = 1, crossSpokes do
            local angle = ((i - 1) * (math.pi * 2 / crossSpokes)) + spinStep
            local dir = Vector2.new(math.cos(angle), math.sin(angle))
            local cLine = Drawing.new("Line")
            
            cLine.Visible = true
            cLine.From = midPoint + (dir * crossGap)
            cLine.To = midPoint + (dir * (crossGap + crossLength))
            cLine.Thickness = crossWidth
            cLine.Color = crossCol
            cLine.Transparency = 1 - crossTrans
            
            table.insert(crosshairLines, cLine)
        end
    else 
        centerDot.Visible = false 
    end

    if UserInputService:IsMouseButtonPressed(aimKey) and aimbotEnabled and lockedTarget then
        cam.CFrame = cam.CFrame:Lerp(CFrame.lookAt(cam.CFrame.Position, lockedTarget.Position), 1 / (aimSmooth + 1))
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed) 
    if not gameProcessed and input.KeyCode == Enum.KeyCode.Delete then 
        mainFrame.Visible = not mainFrame.Visible
        if not mainFrame.Visible then 
            colorPopup.Visible = false 
        end
    end 
end)

