local function createToggle(textVal, currentState, parentObj, callbackFunc)
    orderIndex = orderIndex + 1
    local state = currentState
    local btn = Instance.new("TextButton", parentObj)
    btn.Size = UDim2.new(1, -20, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
    btn.Font = Enum.Font.Code
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Text = textVal .. ": " .. (state and "ON" or "OFF")
    btn.LayoutOrder = orderIndex
    applyCorner(btn)
    
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = textVal .. ": " .. (state and "ON" or "OFF")
        btn.TextColor3 = state and Color3.fromRGB(255, 105, 180) or Color3.new(1, 1, 1)
        callbackFunc(state)
    end)
    
    if state then 
        btn.TextColor3 = Color3.fromRGB(255, 105, 180) 
    end
end

local function createSlider(textVal, currentNum, minNum, maxNum, parentObj, callbackFunc)
    orderIndex = orderIndex + 1
    local frame = Instance.new("Frame", parentObj)
    frame.Size = UDim2.new(1, -20, 0, 45)
    frame.BackgroundTransparency = 1
    frame.LayoutOrder = orderIndex
    
    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, 0, 0, 15)
    title.Text = textVal .. ": " .. currentNum
    title.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    title.Font = Enum.Font.Code
    title.BackgroundTransparency = 1
    
    local sliderBack = Instance.new("Frame", frame)
    sliderBack.Size = UDim2.new(1, 0, 0, 8)
    sliderBack.Position = UDim2.new(0, 0, 0, 22)
    sliderBack.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    applyCorner(sliderBack)
    
    local sliderFill = Instance.new("Frame", sliderBack)
    sliderFill.Size = UDim2.new((currentNum - minNum) / (maxNum - minNum), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(255, 105, 180)
    applyCorner(sliderFill)
    
    sliderBack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true
            local moveConn
            moveConn = RunService.RenderStepped:Connect(function()
                if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then 
                    moveConn:Disconnect()
                    isDragging = false 
                    return 
                end
                
                local mPos = UserInputService:GetMouseLocation()
                local perc = math.clamp((mPos.X - sliderBack.AbsolutePosition.X) / sliderBack.AbsoluteSize.X, 0, 1)
                local finalVal = math.floor(minNum + (perc * (maxNum - minNum)))
                
                title.Text = textVal .. ": " .. finalVal .. "/" .. maxNum
                sliderFill.Size = UDim2.new(perc, 0, 1, 0)
                callbackFunc(finalVal)
            end)
        end
    end)
end

local function createColorPicker(textVal, currentCol, currentAlpha, parentObj, callbackFunc)
    orderIndex = orderIndex + 1
    local frame = Instance.new("Frame", parentObj)
    frame.Size = UDim2.new(1, -20, 0, 35)
    frame.BackgroundTransparency = 1
    frame.LayoutOrder = orderIndex
    
    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, 0, 1, 0)
    title.Text = "  " .. textVal
    title.TextColor3 = Color3.new(1, 1, 1)
    title.Font = Enum.Font.Code
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.BackgroundTransparency = 1
    
    local colorBtn = Instance.new("TextButton", frame)
    colorBtn.Size = UDim2.new(0, 40, 0, 20)
    colorBtn.Position = UDim2.new(1, -45, 0.5, -10)
    colorBtn.Text = ""
    colorBtn.BackgroundColor3 = currentCol
    applyCorner(colorBtn)
    
    colorBtn.MouseButton1Click:Connect(function()
        colorPopup.Visible = false 
        
        colorCallback = function(col, trans) 
            colorBtn.BackgroundColor3 = col
            callbackFunc(col, trans) 
        end
        
        local tempH, tempS, tempV = colorBtn.BackgroundColor3:ToHSV()
        h = tempH
        v = tempS == 1 and tempV / 2 or 0.5 + ((1 - tempS) / 2)
        a = 1 - currentAlpha
        
        huePick.Position = UDim2.new(h, 0, 0.5, 0)
        valPick.Position = UDim2.new(v, 0, 0.5, 0)
        alphaPick.Position = UDim2.new(a, 0, 0.5, 0)
        alphaFill.Size = UDim2.new(a, 0, 1, 0)
        
        local mPos = UserInputService:GetMouseLocation()
        colorPopup.Position = UDim2.new(0, mPos.X + 20, 0, mPos.Y - 50)
        colorPopup.Visible = true
    end)
end

