local function updateColor()
    local baseCol = Color3.fromHSV(h, 1, 1)
    valGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.new(0,0,0)), 
        ColorSequenceKeypoint.new(0.5, baseCol), 
        ColorSequenceKeypoint.new(1, Color3.new(1,1,1))
    })
    
    if colorCallback then
        local sat = v <= 0.5 and 1 or 1 - ((v - 0.5) * 2)
        local val = v <= 0.5 and v * 2 or 1
        colorCallback(Color3.fromHSV(h, sat, val), 1 - a)
    end
end

local function makeSliderDrag(obj, callbackFunc)
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true
            local dragConn
            dragConn = RunService.RenderStepped:Connect(function()
                if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then 
                    dragConn:Disconnect()
                    isDragging = false 
                    return 
                end
                
                local mPos = UserInputService:GetMouseLocation()
                local perc = math.clamp((mPos.X - obj.AbsolutePosition.X) / obj.AbsoluteSize.X, 0, 1)
                callbackFunc(perc)
            end)
        end
    end)
end

makeSliderDrag(hueBack, function(perc) h = perc; huePick.Position = UDim2.new(perc, 0, 0.5, 0); updateColor() end)
makeSliderDrag(valBack, function(perc) v = perc; valPick.Position = UDim2.new(perc, 0, 0.5, 0); updateColor() end)
makeSliderDrag(alphaBack, function(perc) a = perc; alphaFill.Size = UDim2.new(perc, 0, 1, 0); alphaPick.Position = UDim2.new(perc, 0, 0.5, 0); updateColor() end)

