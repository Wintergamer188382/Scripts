unloadAction.Position = UDim2.new(1, -130, 1, -45)
unloadAction.BackgroundColor3 = Color3.fromRGB(60, 20, 20)
unloadAction.Font = Enum.Font.Code
unloadAction.TextColor3 = Color3.new(1, 0.5, 0.5)
