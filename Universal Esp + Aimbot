local function update_cp()
	local base = Color3.fromHSV(h, 1, 1)
	v_g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.new(0,0,0)), ColorSequenceKeypoint.new(0.5, base), ColorSequenceKeypoint.new(1, Color3.new(1,1,1))})
	if pick_fn then
		local s_val = v <= 0.5 and 1 or 1 - ((v - 0.5) * 2)
		local v_val = v <= 0.5 and v * 2 or 1
		pick_fn(Color3.fromHSV(h, s_val, v_val))
	end
end

local function drag(o, fn)
	o.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			local c; c = RunService.RenderStepped:Connect(function()
				if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then c:Disconnect(); dragging = false; return end
				local m = UserInputService:GetMouseLocation()
				fn(math.clamp((m.X - o.AbsolutePosition.X) / o.AbsoluteSize.X, 0, 1))
			end)
		end
	end)
end

