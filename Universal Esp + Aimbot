local function make_esp(p)
	local b = Drawing.new("Square"); b.Thickness = 1; b.Filled = false
	local h_bg = Drawing.new("Line"); h_bg.Thickness = 2; h_bg.Color = Color3.new(0,0,0)
	local h_br = Drawing.new("Line"); h_br.Thickness = 2
	esp[p] = {Box = b, Health = h_br, HealthBack = h_bg}
end

RunService.RenderStepped:Connect(function()
	if not menu_up then return end
	local m_pos = UserInputService:GetMouseLocation()
	local target, dist = nil, size

	for _, p in pairs(Players:GetPlayers()) do
		if p ~= lp and p.Character then
			local hrp = p.Character:FindFirstChild("HumanoidRootPart")
			local hum = p.Character:FindFirstChildOfClass("Humanoid")
			if p.Character:FindFirstChild(part) and hum and hum.Health > 0 then
				local s_pos, vis = camera:WorldToViewportPoint(p.Character[part].Position)
				if vis then
					local m = (Vector2.new(s_pos.X, s_pos.Y) - m_pos).Magnitude
					if m < dist then dist = m; target = p.Character[part] end
				end
			end
			local hl = chams:FindFirstChild(p.Name)
			if ch_on then
				if not hl then hl = Instance.new("Highlight", chams); hl.Name = p.Name end
				hl.Adornee = p.Character; hl.FillColor = ch_f_clr; hl.FillTransparency = ch_f_trans; hl.OutlineColor = ch_o_clr; hl.OutlineTransparency = ch_o_trans; hl.DepthMode = ch_occ and 1 or 0
			elseif hl then hl:Destroy() end
			if not esp[p] then make_esp(p) end
			local d = esp[p]
			if hrp and hum and hum.Health > 0 and e_on then
				local pos, vis = camera:WorldToViewportPoint(hrp.Position)
				if vis then
					local sy = (camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3.5, 0)).Y - camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.8, 0)).Y)
					local sx = sy / 1.8
					d.Box.Visible = e_box; d.Box.Size = Vector2.new(sx, sy); d.Box.Position = Vector2.new(pos.X - sx/2, pos.Y - sy/2); d.Box.Color = e_clr
					if e_health then
						d.HealthBack.Visible = true; d.HealthBack.From = Vector2.new(pos.X-sx/2-4, pos.Y+sy/2); d.HealthBack.To = Vector2.new(pos.X-sx/2-4, pos.Y-sy/2)
						d.Health.Visible = true; d.Health.From = Vector2.new(pos.X-sx/2-4, pos.Y+sy/2); d.Health.To = Vector2.new(pos.X-sx/2-4, (pos.Y+sy/2)-(sy*(hum.Health/hum.MaxHealth))); d.Health.Color = Color3.new(1,0,0):Lerp(Color3.new(0,1,0), hum.Health/hum.MaxHealth)
					else d.Health.Visible = false; d.HealthBack.Visible = false end
				else d.Box.Visible = false; d.Health.Visible = false; d.HealthBack.Visible = false end
			else d.Box.Visible = false; d.Health.Visible = false; d.HealthBack.Visible = false end
		end
	end

	circ.Position = m_pos; circ.Radius = size; circ.Visible = o_on; circ.Color = o_clr; circ.Transparency = 1-o_trans
	fill.Position = m_pos; fill.Radius = size; fill.Visible = f_on; fill.Color = f_clr; fill.Transparency = 1-f_trans
	if target and (n_on or h_on or d_on) then
		local s = ""; if n_on then s = s..target.Parent.Name.."\n" end
		if h_on then s = s.."HP: "..math.floor(target.Parent:FindFirstChildOfClass("Humanoid").Health).."\n" end
		if d_on then s = s..math.floor((lp.Character.Head.Position - target.Position).Magnitude).."m" end
		text.Visible = true; text.Text = s; text.Position = m_pos + Vector2.new(0, size + 10)
	else text.Visible = false end

	kill_lines()
	if c_on then
		local mid = m_pos; if c_fol and target then local p = camera:WorldToViewportPoint(target.Position); mid = Vector2.new(p.X, p.Y) end
		dot.Visible = c_dot; dot.Position = mid; dot.Color = c_clr; dot.Radius = c_wid; dot.Transparency = 1-c_trans
		step = step + ((c_spin^2)/400)
		for i = 1, c_spokes do
			local a = ((i-1)*(math.pi*2/c_spokes))+step; local d = Vector2.new(math.cos(a), math.sin(a))
			local l = Drawing.new("Line"); l.Visible = true; l.From = mid+(d*c_gap); l.To = mid+(d*(c_gap+c_len)); l.Thickness = c_wid; l.Color = c_clr; l.Transparency = 1-c_trans; table.insert(c_lines, l)
		end
	else dot.Visible = false end

	if UserInputService:IsMouseButtonPressed(key) and active and target then
		camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, target.Position), 1/(smooth+1))
	end
end)

