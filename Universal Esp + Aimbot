local function slider(t, cur, min, max, p, fn)
	idx = idx + 1
	local f = Instance.new("Frame", p); f.Size = UDim2.new(1, -20, 0, 45); f.BackgroundTransparency = 1; f.LayoutOrder = idx
	local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 15); l.Text = t .. ": " .. cur; l.TextColor3 = Color3.new(0.8,0.8,0.8); l.Font = "Code"; l.BackgroundTransparency = 1
	local b = Instance.new("Frame", f); b.Size = UDim2.new(1, 0, 0, 8); b.Position = UDim2.new(0, 0, 0, 22); b.BackgroundColor3 = Color3.fromRGB(35,35,35); round(b)
	local i = Instance.new("Frame", b); i.Size = UDim2.new((cur-min)/(max-min), 0, 1, 0); i.BackgroundColor3 = Color3.fromRGB(255, 105, 180); round(i)
	b.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			local move; move = RunService.RenderStepped:Connect(function()
				if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then move:Disconnect(); dragging = false; return end
				local x = math.clamp((UserInputService:GetMouseLocation().X - b.AbsolutePosition.X) / b.AbsoluteSize.X, 0, 1)
				local val = math.floor(min + (x * (max - min)))
				l.Text = t .. ": " .. val .. "/" .. max; i.Size = UDim2.new(x, 0, 1, 0)
				fn(val)
			end)
		end
	end)
end

