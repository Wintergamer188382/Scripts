local function buildColumn(pos, parentObj)
    local container = Instance.new("Frame", parentObj)
    container.Size = UDim2.new(0.33, -10, 1, -20)
    container.Position = pos
    container.BackgroundTransparency = 1
    
    local scrollFrame = Instance.new("ScrollingFrame", container)
    scrollFrame.Size = UDim2.new(1, 0, 1, 0)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.BorderSizePixel = 0
    scrollFrame.ScrollBarThickness = 2
    
    local listHolder = Instance.new("Frame", scrollFrame)
    listHolder.Size = UDim2.new(1, 0, 0, 0)
    listHolder.BackgroundTransparency = 1
    
    local layout = Instance.new("UIListLayout", listHolder)
    layout.Padding = UDim.new(0, 10)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() 
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20) 
    end)
    
    return listHolder
end

