    mainGui:Destroy()
    popupGui:Destroy()
    fovOutline:Remove()
    fovFill:Remove()
    targetText:Remove()
    centerDot:Remove()
    clearLines() 
    
    for _, cache in pairs(espCache) do 
        cache.Box:Remove()
        cache.Health:Remove()
        cache.HealthBack:Remove() 
    end 
end)
