    sync()

    task.spawn(function()
        while true do
            if Config[rainbowVar] then
                local hue = tick() % Config[speedVar] / Config[speedVar]
                local rbCol = Color3.fromHSV(hue, 1, 1)
                Config[var] = rbCol
                colorPreview.BackgroundColor3 = rbCol
                knob.Position = UDim2.new(hue, 0, 0.5, 0)
                UpdateMainUIColours()
            end
            task.wait()
        end
    end)
end

