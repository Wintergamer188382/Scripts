local function SaveConfig()
    local data = {
        Config = {},
        LootToggles = LootToggles,
        LootSettingsData = LootSettingsData
    }
    for k, v in pairs(Config) do
        if typeof(v) == "Color3" then
            data.Config[k] = {v.R, v.G, v.B}
        else
            data.Config[k] = v
        end
    end
    writefile("EpstienConfigs/" .. Config.SelectedConfigName .. ".json", HttpService:JSONEncode(data))
end

local function LoadConfig(name)
    local fileName = "EpstienConfigs/" .. name .. ".json"
    if isfile(fileName) then
        local raw = readfile(fileName)
        local data = HttpService:JSONDecode(raw)
        
        if data.Config then
            for k, v in pairs(data.Config) do
                if type(v) == "table" and #v == 3 then
                    Config[k] = Color3.new(v[1], v[2], v[3])
                else
                    Config[k] = v
                end
            end
        end

        if data.LootToggles then
            for k, v in pairs(data.LootToggles) do
                LootToggles[k] = v
            end
        end

        if data.LootSettingsData then
            LootSettingsData = data.LootSettingsData
        end
        
        UpdateUI()
    end
end

