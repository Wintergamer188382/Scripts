local function CreateGlowTracer(start, target)
    if not Config.TracerEnabled then return end
    local beamPart = Instance.new("Part", workspace)
    beamPart.Anchored = true; beamPart.CanCollide = false; beamPart.Transparency = 1; beamPart.Size = Vector3.new(0.1, 0.1, 0.1)
    
    local att0 = Instance.new("Attachment", beamPart); att0.WorldPosition = start
    local att1 = Instance.new("Attachment", beamPart); att1.WorldPosition = target
    
    local beam = Instance.new("Beam", beamPart)
    beam.Attachment0 = att0; beam.Attachment1 = att1
    
    beam.Texture = Config.TracerTexture
    beam.TextureMode = Enum.TextureMode.Wrap
    beam.Width0, beam.Width1 = 2, 2
    beam.Transparency = NumberSequence.new(0)
    beam.Color = ColorSequence.new(Config.TracerColor)
    
    beam.LightEmission = 1 
    beam.LightInfluence = 0 
    beam.FaceCamera = true
    beam.ZOffset = 2
    
    task.spawn(function()
        local startTime = tick()
        while tick() - startTime < Config.TracerTime and Running do
            if Config.RainbowTracer then
                local hue = tick() % Config.TracerRSpeed / Config.TracerRSpeed
                beam.Color = ColorSequence.new(Color3.fromHSV(hue, 1, 1))
            end
            task.wait()
        end
    end)
    
    Debris:AddItem(beamPart, Config.TracerTime)
end

