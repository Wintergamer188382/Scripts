local function ApplyLootCham(container)
    local attachment = container:FindFirstChild("Attachment")
    local prompt = attachment and attachment:FindFirstChild("ContainerPrompt")
    if not prompt or not prompt:IsA("ProximityPrompt") then return end

    local objectName = prompt.ObjectText
    local setting = LootSettings[objectName]
    if not setting then return end

    local adorneePart = container:FindFirstChild("Main") or container:IsA("BasePart") and container or container:FindFirstChildOfClass("BasePart")
    if not adorneePart then return end

    local box = Instance.new("BoxHandleAdornment")
    box.Name = "GeminiLootCham"
    box.Size = adorneePart.Size + Vector3.new(0.05, 0.05, 0.05)
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Adornee = adorneePart
    box.Color3 = setting.Color
    box.Transparency = 0.5
    box.Visible = false
    box.Parent = adorneePart

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not Running or not container or not container.Parent then
            box:Destroy(); connection:Disconnect()
            return
        end
        local isEnabled = LootToggles[objectName]
        box.Visible = isEnabled
    end)
end

