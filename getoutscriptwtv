            if hp >= 9e9 or hp ~= hp then -- Check for extreme numbers or NaN
                isSuspect = true
                suspectReason = "possible mod (godmode)"
            end
        end

        -- Priority 3: Check for Invisible Parts
        if not isSuspect and char then
            for _, p in pairs(char:GetChildren()) do
                if p:IsA("BasePart") and p.Transparency >= 0.9 then
                    local ignore = false
                    for _, n in pairs(IgnoredParts) do if p.Name == n then ignore = true break end end
                    if not ignore then isSuspect = true break end
                end
            end
        end

        -- Handle suspect tracking and UI entry
        if isSuspect then
            if not InvisTimers[userId] then InvisTimers[userId] = tick() end
            if tick() - InvisTimers[userId] >= InvisThreshold and not ActiveEntries[userId] then
                CreateEntry(player, suspectReason, true)
            end
        else
            InvisTimers[userId] = nil
            if ActiveEntries[userId] and ActiveEntries[userId].Type == "Invis" then RemoveEntry(userId) end
        end
    end
end)

Players.PlayerRemoving:Connect(function(player)
    RemoveEntry(player.UserId); InvisTimers[player.UserId] = nil
end)
