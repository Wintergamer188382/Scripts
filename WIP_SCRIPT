    end
    CrosshairDot = NewDrawing("Circle")
    if CrosshairDot then
        CrosshairDot.Filled = true
        CrosshairDot.Visible = false
        CrosshairDot.ZIndex = 105
    end
    for i = 1, 12 do
        local line = NewDrawing("Line")
        if line then
            line.Visible = false
            line.Thickness = Config.Crosshair.Width
            line.Color = Config.Crosshair.Color
            line.Transparency = 1 - Config.Crosshair.Trans
            table.insert(CrosshairLines, line)
        end
    end
    DrawingAvailable = FOVInfoText ~= nil or CrosshairDot ~= nil or #CrosshairLines > 0
end

local function UpdateCrosshair()
    if not DrawingAvailable then return end
    local mousePos = UserInputService:GetMouseLocation()
    local mid = mousePos
    if Config.Crosshair.FollowTarget then
        local activeTarget = GetActiveTarget()
        if activeTarget then
            local p, onScreen = Camera:WorldToViewportPoint(activeTarget.Position)
            if onScreen then mid = Vector2.new(p.X, p.Y) end
        end
    end
    CrosshairDot.Visible = Config.Crosshair.Enabled and Config.Crosshair.CenterDot
    if CrosshairDot.Visible then
        CrosshairDot.Position = mid
        CrosshairDot.Radius = Config.Crosshair.Width
        CrosshairDot.Color = Config.Crosshair.Color
        CrosshairDot.Transparency = 1 - Config.Crosshair.Trans
    end
    local stepSpeed = (Config.Crosshair.Spin ^ 2) / 400
    CrosshairStep = CrosshairStep + stepSpeed
    for i = 1, #CrosshairLines do
        local line = CrosshairLines[i]
        if i <= Config.Crosshair.Spokes and Config.Crosshair.Enabled then
            local angle = ((i - 1) * (math.pi * 2 / Config.Crosshair.Spokes)) + CrosshairStep
            local dir = Vector2.new(math.cos(angle), math.sin(angle))
            line.Visible = true
            line.From = mid + dir * Config.Crosshair.Gap
            line.To = mid + dir * (Config.Crosshair.Gap + Config.Crosshair.Length)
            line.Color = Config.Crosshair.Color
            line.Thickness = Config.Crosshair.Width
            line.Transparency = 1 - Config.Crosshair.Trans
        else
            line.Visible = false
        end
    end
end

local function RefreshFOVInfoText()
    if not DrawingAvailable or not FOVInfoText then return end
    local target = GetActiveTarget()
    local parts = {}
    if Config.Aimbot.ShowWeapon then
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then
            table.insert(parts, "Weapon: " .. tool.Name)
        else
            table.insert(parts, "Weapon: None")
        end
    end
    if target and target.Parent then
        local hum = target.Parent:FindFirstChildOfClass("Humanoid")
        if Config.Aimbot.ShowName then
            table.insert(parts, "Name: " .. target.Parent.Name)
        end
        if Config.Aimbot.ShowHealth and hum then
            table.insert(parts, "HP: " .. math.floor(hum.Health))
        end
    end
    if #parts == 0 then
        FOVInfoText.Visible = false
        return
    end
    local text = table.concat(parts, "\n")
    FOVInfoText.Text = text
    local mousePos = UserInputService:GetMouseLocation()
    FOVInfoText.Position = mousePos + Vector2.new(0, Config.SilentAim.FOV + 18)
    FOVInfoText.Color = Config.SilentAim.FOVColor
    FOVInfoText.Transparency = 0
    FOVInfoText.Visible = (Config.SilentAim.Enabled or Config.Aimbot.Enabled)
end

