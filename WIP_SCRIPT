    ResetFOVFill(false)

    -- // Reset slider visuals
    ResetFOV(100)
    ResetAimbotSmoothing(Defaults.AimbotSmoothing)
    ResetSpeedSlider(24)
    ResetFillTrans(Defaults.FillTrans)
    ResetFOVFillTrans(Defaults.FOVFillTrans)
    ResetOutlineTrans(Defaults.OutlineTrans)
    ResetCrosshairSpokes(Config.Crosshair.Spokes)
    ResetCrosshairLength(Config.Crosshair.Length)
    ResetCrosshairGap(Config.Crosshair.Gap)
    ResetCrosshairWidth(Config.Crosshair.Width)
    ResetCrosshairSpin(Config.Crosshair.Spin)
    ResetCrosshairTrans(0)

    -- // Close color picker if open
    if ActiveColorPicker then CloseColorPicker() end

    -- // Cleanup
    ChamsFolder:ClearAllChildren()
    ChamsFolder:Destroy()
    if TriggerBotConnection then TriggerBotConnection:Disconnect(); TriggerBotConnection = nil end
    if SilentAimConnection then SilentAimConnection:Disconnect(); SilentAimConnection = nil end
    if ChamsConnection then ChamsConnection:Disconnect(); ChamsConnection = nil end
    if FOVCircleConnection then FOVCircleConnection:Disconnect(); FOVCircleConnection = nil end
    if oldNamecall then hookmetamethod(game, "__namecall", oldNamecall) end
    ScreenGui:Destroy()
end

