-- // Slider component (original dash-bracket style)
local function AddSlider(parent, tabName, feature, min, max, default, callback)
    local val = default
    local ext = GetRandomExt()
    local Btn = Instance.new("TextButton", parent)
    Btn.BackgroundTransparency = 1
    Btn.Size = UDim2.new(1, 0, 0, 25)
    Btn.Font = Enum.Font.Code
    Btn.TextColor3 = COLORS.TEXT_MAIN
    Btn.TextSize = 16
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    local function UpdateSlider()
        local pct = math.clamp((val - min) / (max - min), 0, 1)
        local dc = math.floor(pct * 30)
        local bar = "[" .. string.rep("-", dc) .. string.rep(" ", 30 - dc) .. "]"
        Btn.Text = string.format("%s%s %s %d (%d%%)", feature, ext, bar, val, (val / max) * 100)
    end
    local function ForceVal(v) val = v; UpdateSlider() end
    local dragging = false
    local function GetBounds()
        local prefix = feature .. ext .. " "
        local ps = TextService:GetTextSize(prefix, Btn.TextSize, Btn.Font, Vector2.new(math.huge, math.huge))
        local bs = TextService:GetTextSize("[------------------------------]", Btn.TextSize, Btn.Font, Vector2.new(math.huge, math.huge))
        return Btn.AbsolutePosition.X + ps.X, Btn.AbsolutePosition.X + ps.X + bs.X
    end
    local function HandleInput()
        local mx = UserInputService:GetMouseLocation().X
        local bS, bE = GetBounds()
        local rel = math.clamp((mx - bS) / (bE - bS), 0, 1)
        val = math.clamp(math.floor(min + (max - min) * rel + 0.5), min, max)
        UpdateSlider(); callback(val)
    end
    Btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mx = UserInputService:GetMouseLocation().X
            local bS, bE = GetBounds()
            if mx >= bS and mx <= bE then dragging = true; HandleInput() end
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false; Notify(feature .. " updated to " .. val)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then HandleInput() end
    end)
    UpdateSlider()
    parent.CanvasSize = UDim2.new(0, 0, 0, parent.UIListLayout.AbsoluteContentSize.Y)
    return ForceVal
end

local RecoilSpreadCache = {}
local FireRateCache = {}

local function ApplyRecoilSpreadTag(o)
    if o:GetAttribute("Recoil") then
        local data = RecoilSpreadCache[o] or {}
        if data.Recoil == nil then data.Recoil = o:GetAttribute("Recoil") end
        o:SetAttribute("Recoil", 0)
        if data.Spread == nil and o:GetAttribute("Spread") then data.Spread = o:GetAttribute("Spread") end
        if o:GetAttribute("Spread") then o:SetAttribute("Spread", 0) end
        RecoilSpreadCache[o] = data
    elseif o:GetAttribute("Spread") then
        local data = RecoilSpreadCache[o] or {}
        if data.Spread == nil then data.Spread = o:GetAttribute("Spread") end
        o:SetAttribute("Spread", 0)
        RecoilSpreadCache[o] = data
    end
end

local function RestoreRecoilSpread(o)
    local data = RecoilSpreadCache[o]
    if not data then return end
    if data.Recoil then o:SetAttribute("Recoil", data.Recoil) end
    if data.Spread then o:SetAttribute("Spread", data.Spread) end
    RecoilSpreadCache[o] = nil
end

local function ApplyFireRateTag(o)
    if o:GetAttribute("FireRate") then
        if FireRateCache[o] == nil then
            FireRateCache[o] = o:GetAttribute("FireRate")
        end
        o:SetAttribute("FireRate", FireRateCache[o] * 1.25)
    end
end

local function RestoreFireRate(o)
    if FireRateCache[o] and o:GetAttribute("FireRate") then
        o:SetAttribute("FireRate", FireRateCache[o])
        FireRateCache[o] = nil
    end
end

local function RefreshCombatAttributes()
    for _, o in pairs(LocalPlayer:GetDescendants()) do
        if Config.Combat.RecoilSpread then
            ApplyRecoilSpreadTag(o)
        else
            RestoreRecoilSpread(o)
        end
        if Config.Combat.FireRate then
            ApplyFireRateTag(o)
        else
            RestoreFireRate(o)
        end
    end
end

LocalPlayer.DescendantAdded:Connect(function(o)
    if Config.Combat.RecoilSpread then ApplyRecoilSpreadTag(o) end
    if Config.Combat.FireRate then ApplyFireRateTag(o) end
end)

