FOVCircleConnection = RunService.RenderStepped:Connect(function()
    if not Config.Running then
        FOVCircle.Visible = false
        FOVFillFrame.Visible = false
        if FOVInfoText then FOVInfoText.Visible = false end
        return
    end
    local mouse = UserInputService:GetMouseLocation()
    local size = Config.SilentAim.FOV * 2
    FOVCircle.Position = UDim2.new(0, mouse.X, 0, mouse.Y)
    FOVCircle.Size = UDim2.new(0, size, 0, size)
    FOVCircle.Visible = Config.SilentAim.Enabled or Config.Aimbot.Enabled
    FOVStroke.Color = Config.SilentAim.FOVColor

    FOVFillFrame.Position = FOVCircle.Position
    FOVFillFrame.Size = FOVCircle.Size
    FOVFillFrame.BackgroundColor3 = Config.SilentAim.FillColor
    FOVFillFrame.BackgroundTransparency = 1 - Config.SilentAim.FillTrans
    FOVFillFrame.Visible = Config.SilentAim.FillEnabled and (Config.SilentAim.Enabled or Config.Aimbot.Enabled)

    UpdateAimbot()
    UpdateCrosshair()
    RefreshFOVInfoText()
end)
