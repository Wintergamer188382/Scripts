local function GetActiveTarget()
    if Config.SilentAim.Enabled then
        return CurrentTarget
    end
    return AimbotTarget
end

local function UpdateAimbot()
    if not Config.Running or not Config.Aimbot.Enabled then
        AimbotTarget = nil
        return
    end
    AimbotTarget = GetAimbotTarget()
    if AimbotTarget and UserInputService:IsMouseButtonPressed(Config.Aimbot.Key) then
        local targetPos = AimbotTarget.Position
        local root = AimbotTarget.Parent and AimbotTarget.Parent:FindFirstChild("HumanoidRootPart")
        if root then
            targetPos = targetPos + (root.Velocity * Config.Aimbot.PredictionAmount)
        end
        local look = CFrame.lookAt(Camera.CFrame.Position, targetPos)
        Camera.CFrame = Camera.CFrame:Lerp(look, 1 / (math.max(0, Config.Aimbot.Smoothing) + 1))
    end
end

local function SetupFOVDrawings()
    if typeof(Drawing) ~= "table" then
