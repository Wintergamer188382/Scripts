-- // [ADDED] WORLD helpers and effects
local WorldTextureCache = {}
local FoliageTransparencyCache = {}

local function ApplyAmbientColor(color)
    if Lighting then
        Lighting.Ambient = color
        Lighting.OutdoorAmbient = color
        Lighting.ColorShift_Top = color
        Lighting.ColorShift_Bottom = color
        Lighting.FogColor = color
        local atmosphere = Lighting:FindFirstChildOfClass("Atmosphere")
        if atmosphere then
            atmosphere.SkyColor = color
            atmosphere.HazeColor = color
        end
    end
end

local function SetRemoveTextures(enabled)
    if enabled then
        WorldTextureCache = {}
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Texture") or obj:IsA("Decal") or obj:IsA("SurfaceAppearance") then
                if obj.Parent then
                    table.insert(WorldTextureCache, {Clone = obj:Clone(), Parent = obj.Parent})
                    obj:Destroy()
                end
            end
        end
    else
        for _, entry in ipairs(WorldTextureCache) do
            if entry.Clone and entry.Parent then
                entry.Clone.Parent = entry.Parent
            end
        end
        WorldTextureCache = {}
    end
end

local function ApplyBrightness(value)
    if Lighting then
        Lighting.Brightness = value
    end
end

local function ApplyClockTime(value)
    if Lighting then
        Lighting.ClockTime = value
    end
end

local function SetFoliageVisibility(enabled)
    if not foliageFolder and not grassFolder then return end
    if enabled then
        FoliageTransparencyCache = {}
        for _, folder in ipairs({foliageFolder, grassFolder}) do
            if folder then
                for _, desc in ipairs(folder:GetDescendants()) do
                    if desc:IsA("BasePart") then
                        FoliageTransparencyCache[desc] = desc.Transparency
                        desc.Transparency = 1
                    end
                end
            end
        end
    else
        for part, original in pairs(FoliageTransparencyCache) do
            if part and part.Parent then
                part.Transparency = original
            end
        end
        FoliageTransparencyCache = {}
    end
end

