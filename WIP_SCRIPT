        {lbl = "B", getV = function() return b end, setV = function(v) b = v end, dashColor = Color3.fromRGB(60, 120, 220)},
    }

    for _, ch in ipairs(channels) do
        -- // Each channel row uses RichText to color the dashes
        local Row = Instance.new("TextButton", PC)
        Row.BackgroundTransparency = 1
        Row.Size = UDim2.new(1, -50, 0, 22)
        Row.Font = Enum.Font.Code
        Row.TextSize = 15
        Row.TextColor3 = COLORS.TEXT_MAIN
        Row.TextXAlignment = Enum.TextXAlignment.Left
        Row.AutoButtonColor = false
        Row.RichText = true
        Row.ZIndex = 2003

        local hexDash = string.format("#%02X%02X%02X", 
            math.floor(ch.dashColor.R * 255), 
            math.floor(ch.dashColor.G * 255), 
            math.floor(ch.dashColor.B * 255))

        local function UpdateRow()
            local v = ch.getV()
            local pct = v / 255
            local dc = math.floor(pct * 20)
            -- // Colored dashes via RichText font tag
            local coloredDashes = string.format('<font color="%s">%s</font>', hexDash, string.rep("-", dc))
            local emptySpaces = string.rep(" ", 20 - dc)
            local bar = "[" .. coloredDashes .. emptySpaces .. "]"
            Row.Text = string.format('%s.exe %s %d (%d%%)', ch.lbl, bar, v, math.floor(pct * 100))
        end

        local rowDragging = false
        local function GetRowBounds()
            local prefix = ch.lbl .. ".exe "
            local ps = TextService:GetTextSize(prefix, 15, Enum.Font.Code, Vector2.new(math.huge, math.huge))
            local bs = TextService:GetTextSize("[--------------------]", 15, Enum.Font.Code, Vector2.new(math.huge, math.huge))
            return Row.AbsolutePosition.X + ps.X, Row.AbsolutePosition.X + ps.X + bs.X
        end
        local function HandleRow()
            local mx = UserInputService:GetMouseLocation().X
            local bS, bE = GetRowBounds()
            ch.setV(math.floor(math.clamp((mx - bS) / (bE - bS), 0, 1) * 255))
            UpdateRow(); RefreshAll()
        end
        Row.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mx = UserInputService:GetMouseLocation().X
                local bS, bE = GetRowBounds()
                if mx >= bS and mx <= bE then rowDragging = true; HandleRow() end
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 and rowDragging then
                rowDragging = false; Notify(label .. " " .. ch.lbl .. " = " .. ch.getV())
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if rowDragging and input.UserInputType == Enum.UserInputType.MouseMovement then HandleRow() end
        end)
        UpdateRow()
    end

    -- // [ADDED] Rainbow toggle — same dash-bracket text style as main toggles
    local rbState = false
    local RbBtn = Instance.new("TextButton", PC)
    RbBtn.BackgroundTransparency = 1
    RbBtn.Size = UDim2.new(1, -50, 0, 22)
    RbBtn.Font = Enum.Font.Code
    RbBtn.TextSize = 15
    RbBtn.TextColor3 = COLORS.TEXT_MAIN
    RbBtn.TextXAlignment = Enum.TextXAlignment.Left
    RbBtn.AutoButtonColor = false
    RbBtn.ZIndex = 2003

    local RbStatus = Instance.new("TextLabel", RbBtn)
    RbStatus.BackgroundTransparency = 1
    RbStatus.Size = UDim2.new(1, 0, 1, 0)
    RbStatus.Font = Enum.Font.Code
    RbStatus.TextSize = 15
    RbStatus.TextXAlignment = Enum.TextXAlignment.Left
    RbStatus.ZIndex = 2004

    local function RefreshRb()
        local base = "rainbow.exe - "
        RbBtn.Text = base
        RbStatus.Text = string.rep(" ", #base) .. (rbState and "on" or "off")
        RbStatus.TextColor3 = rbState and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    end

    RbBtn.MouseButton1Click:Connect(function()
        rbState = not rbState
        RefreshRb()
        if rbState then
            -- // Rainbow loop updates color continuously while enabled
            rainbowConn = RunService.RenderStepped:Connect(function()
                if not rbState then return end
                local hue = tick() % 5 / 5
                local col = Color3.fromHSV(hue, 1, 1)
                r = math.floor(col.R * 255)
                g = math.floor(col.G * 255)
                b = math.floor(col.B * 255)
                PreviewCircle.BackgroundColor3 = col
                colorTable[colorKey] = col
                if onChanged then onChanged(col) end
                local hex = string.format("#%02X%02X%02X", r, g, b)
                HexLine.Text = string.format("hex: %s   rgb(%d, %d, %d)", hex, r, g, b)
            end)
        else
            if rainbowConn then rainbowConn:Disconnect(); rainbowConn = nil end
            RefreshAll()
        end
    end)
    RefreshRb()

    RefreshAll()
    PC.CanvasSize = UDim2.new(0, 0, 0, PCList.AbsoluteContentSize.Y)
end

