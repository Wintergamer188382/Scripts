local CurrentTarget, TargetVelocity = nil, Vector3.new()
local LastTargetPos, LastTargetTime = nil, tick()

local function GetTarget()
    local mouse = UserInputService:GetMouseLocation()
    local bestDist = Config.SilentAim.FOV
    local target = nil
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            local hum = v.Character:FindFirstChildOfClass("Humanoid")
            local part = v.Character:FindFirstChild(Config.SilentAim.TargetPart)
            if hum and hum.Health > 0 and part then
                local sPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local d = (Vector2.new(sPos.X, sPos.Y) - mouse).Magnitude
                    if d < bestDist then bestDist = d; target = part end
                end
            end
        end
    end
    return target
end

local function IsAlive(plr)
    if not plr or not plr.Character then return false end
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0 and plr.Character:FindFirstChild("HumanoidRootPart")
end

local function GetAimbotTarget()
    local mouse = UserInputService:GetMouseLocation()
    local bestDist = Config.SilentAim.FOV
    local target = nil
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and IsAlive(v) then
            local part = v.Character:FindFirstChild(Config.Aimbot.TargetPart)
            if part then
                local sPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local d = (Vector2.new(sPos.X, sPos.Y) - mouse).Magnitude
                    if d < bestDist then bestDist = d; target = part end
                end
            end
        end
    end
    return target
end

SilentAimConnection = RunService.RenderStepped:Connect(function()
    if not Config.Running then return end
    CurrentTarget = GetTarget()
    if CurrentTarget then
        if LastTargetPos then
            local dt = tick() - LastTargetTime
            if dt > 0 then TargetVelocity = (CurrentTarget.Position - LastTargetPos) / dt end
        end
        LastTargetPos = CurrentTarget.Position
        LastTargetTime = tick()
    end
    if Config.WalkSpeed.Enabled then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = Config.WalkSpeed.Speed end
        end
    end
end)

