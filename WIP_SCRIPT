local function UpdateESP()
    if not Config.Running or not (Config.Chams.ESPBoxes or Config.Chams.ESPNames or Config.Chams.ESPHealth or Config.Chams.ESPTracers) then
        ClearESP(); return
    end

    local screenSize = Camera.ViewportSize
    local originY = Config.Chams.TracerOriginTop and 0 or screenSize.Y
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            local head = plr.Character:FindFirstChild("Head")
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and head and root then
                local topPos, topOn = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.2, 0))
                local bottomPos, bottomOn = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 1, 0))
                if topOn and bottomOn then
                    local container = ESPFolder:FindFirstChild(plr.Name) or CreateESPContainer(plr)
                    local box = container:FindFirstChild("Box")
                    local nameLabel = container:FindFirstChild("Name")
                    local healthBack = container:FindFirstChild("HealthBack")
                    local healthBar = healthBack and healthBack:FindFirstChild("HealthBar")
                    local tracer = container:FindFirstChild("Tracer")

                    local height = math.clamp(math.abs(bottomPos.Y - topPos.Y), 50, 300)
                    local width = math.clamp(height / 2, 45, 160)
                    local boxX = topPos.X - width / 2
                    local boxY = topPos.Y

                    box.Position = UDim2.new(0, boxX, 0, boxY)
                    box.Size = UDim2.new(0, width, 0, height)
                    box.UIStroke.Color = Config.Chams.Outline.Color
                    box.Visible = Config.Chams.ESPBoxes

                    nameLabel.Text = plr.Name
                    nameLabel.Position = UDim2.new(0, boxX, 0, boxY - 18)
                    nameLabel.Size = UDim2.new(0, width, 0, 18)
                    nameLabel.Visible = Config.Chams.ESPNames

                    if healthBack and healthBar then
                        healthBack.Position = UDim2.new(0, boxX, 0, boxY + height + 4)
                        healthBack.Size = UDim2.new(0, width, 0, 8)
                        healthBack.Visible = Config.Chams.ESPHealth
                        healthBar.Size = UDim2.new(math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1), 0, 1, 0)
                        healthBar.BackgroundColor3 = hum.Health > hum.MaxHealth * 0.5 and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 100, 0)
                    end

                    if tracer then
                        tracer.BackgroundColor3 = Config.Chams.Outline.Color
                        tracer.Visible = Config.Chams.ESPTracers
                        local tracerHeight = math.abs(topPos.Y - originY)
                        tracer.Position = UDim2.new(0, topPos.X - 1, 0, math.min(originY, topPos.Y))
                        tracer.Size = UDim2.new(0, 2, 0, tracerHeight)
                    end
                elseif ESPFolder:FindFirstChild(plr.Name) then
                    ESPFolder:FindFirstChild(plr.Name):Destroy()
                end
            elseif ESPFolder:FindFirstChild(plr.Name) then
                ESPFolder:FindFirstChild(plr.Name):Destroy()
            end
        end
    end

    for _, entry in ipairs(ESPFolder:GetChildren()) do
        if not Players:FindFirstChild(entry.Name) then entry:Destroy() end
    end
end

local FlyControl = {W = false, A = false, S = false, D = false, Space = false, Shift = false}
local FlyVelocity, FlyGyro, FlyToggleSetter = nil, nil, nil

local function UpdateFlyVelocity()
    if not Config.Fly.Enabled then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if not FlyVelocity or FlyVelocity.Parent ~= hrp then
        if FlyVelocity then FlyVelocity:Destroy() end
        FlyVelocity = Instance.new("BodyVelocity")
        FlyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        FlyVelocity.P = 10000
        FlyVelocity.Parent = hrp
    end
    if not FlyGyro or FlyGyro.Parent ~= hrp then
        if FlyGyro then FlyGyro:Destroy() end
        FlyGyro = Instance.new("BodyGyro")
        FlyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        FlyGyro.P = 3000
        FlyGyro.Parent = hrp
    end

    local moveDirection = Vector3.new(
        (FlyControl.D and 1 or 0) - (FlyControl.A and 1 or 0),
        (FlyControl.Space and 1 or 0) - (FlyControl.Shift and 1 or 0),
        (FlyControl.W and 1 or 0) - (FlyControl.S and 1 or 0)
    )
    if moveDirection.Magnitude > 0 then
        moveDirection = moveDirection.Unit
        local cam = Camera.CFrame
        local velocity = (cam.LookVector * moveDirection.Z + cam.RightVector * moveDirection.X + Vector3.new(0, moveDirection.Y, 0)) * Config.Fly.Speed
        FlyVelocity.Velocity = velocity
    else
        FlyVelocity.Velocity = Vector3.new(0, 0, 0)
    end
    FlyGyro.CFrame = CFrame.new(hrp.Position, hrp.Position + Camera.CFrame.LookVector)
end

