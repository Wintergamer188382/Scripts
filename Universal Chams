local function make_toggle(txt, val)
	local btn = Instance.new("TextButton", ListHolder)
	btn.Size = UDim2.new(1, -20, 0, 30); btn.BackgroundColor3 = Color3.fromRGB(35,35,35); btn.Text = txt..": OFF"; btn.TextColor3 = Color3.new(1,1,1); btn.Font = "Code"; round(btn, 6)
	btn.MouseButton1Click:Connect(function()
		config[val] = not config[val]
		btn.Text = txt..": "..(config[val] and "ON" or "OFF")
		btn.TextColor3 = config[val] and Color3.new(0,1,0.5) or Color3.new(1,1,1)
	end)
end

local function make_color(txt, k)
	local f = Instance.new("Frame", ListHolder); f.Size = UDim2.new(1, -20, 0, 30); f.BackgroundTransparency = 1
	local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1,0,1,0); l.Text = "  "..txt; l.TextColor3 = Color3.new(0.8,0.8,0.8); l.Font = "Code"; l.TextXAlignment = "Left"; l.BackgroundTransparency = 1
	local b = Instance.new("TextButton", f); b.Size = UDim2.new(0, 20, 0, 20); b.Position = UDim2.new(1, -25, 0.5, -10); b.Text = ""; b.BackgroundColor3 = config[k].color; round(b, 4)
	b.MouseButton1Click:Connect(function()
		if current_key == k then ColorPane.Visible = false; current_key = nil else
			current_key = k; ColorPane.Visible = true; update_pkr()
		end
	end)
	RunService.RenderStepped:Connect(function() b.BackgroundColor3 = config[k].color end)
end

