local current_key = nil
local function update_pkr()
	if not current_key then return end
	local h, s, v = config[current_key].color:ToHSV()
	SV_Canvas.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
	Pointer.Position = UDim2.new(s, 0, 1 - v, 0)
	
	local p = 1 - config[current_key].trans
	slider_fill.Size = UDim2.new(p, 0, 1, 0)
	slider_btn.Position = UDim2.new(p, -2, 0, -2)
	
	RainbowToggle.Text = "RAINBOW: "..(config[current_key].rainbow and "ON" or "OFF")
	RainbowToggle.TextColor3 = config[current_key].rainbow and Color3.new(0, 1, 0.5) or Color3.new(1,1,1)
end

RainbowToggle.MouseButton1Click:Connect(function()
	if current_key then
		config[current_key].rainbow = not config[current_key].rainbow
		update_pkr()
	end
end)

local function hook_input(f, cb)
	f.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			local loop; loop = RunService.RenderStepped:Connect(function()
				local m = UIS:GetMouseLocation()
				local gi = GS:GetGuiInset()
				local rx = math.clamp((m.X - f.AbsolutePosition.X) / f.AbsoluteSize.X, 0, 1)
				local ry = math.clamp((m.Y - gi.Y - f.AbsolutePosition.Y) / f.AbsoluteSize.Y, 0, 1)
				cb(rx, ry)
				update_pkr()
				if not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then loop:Disconnect() end
			end)
		end
	end)
end

hook_input(SV_Canvas, function(x, y)
	local h = config[current_key].color:ToHSV()
	config[current_key].color = Color3.fromHSV(h, x, 1 - y)
end)

hook_input(Hue_Rail, function(x, y)
	local _, s, v = config[current_key].color:ToHSV()
	config[current_key].color = Color3.fromHSV(0.85 - (y * 0.85), s, v)
end)

hook_input(slider_back, function(x, y)
	config[current_key].trans = 1 - x
end)

