RunService.Heartbeat:Connect(function()
	if not config.enabled then 
		cache_folder:ClearAllChildren() 
		return 
	end
	
	local rainbow_col = Color3.fromHSV(tick() % 5 / 5, 1, 1)

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character then
			local high = cache_folder:FindFirstChild(plr.Name)
			if not high then
				high = Instance.new("Highlight", cache_folder)
				high.Name = plr.Name
			end
			high.Adornee = plr.Character
			high.FillColor = config.fill.rainbow and rainbow_col or config.fill.color
			high.OutlineColor = config.outline.rainbow and rainbow_col or config.outline.color
			high.FillTransparency = config.fill.trans
			high.OutlineTransparency = config.outline.trans
			high.DepthMode = config.occluded and Enum.HighlightDepthMode.Occluded or Enum.HighlightDepthMode.AlwaysOnTop
		end
	end
end)
